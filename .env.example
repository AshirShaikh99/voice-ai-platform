# ──────────────────────────────────────────────────────────────
# Voice AI Platform · Phase 1 · .env.example
# Copy this file to .env.local and fill in the values below.
# ──────────────────────────────────────────────────────────────

# Clerk — https://dashboard.clerk.com
# Create a new application, enable "Organizations", then copy the keys from
# Dashboard → API keys. Recommended: disable personal accounts so every user
# must belong to an org.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Route overrides (optional but recommended to keep them consistent).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/select-org
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/select-org

# NeonDB — https://console.neon.tech
# Create a project, copy the pooled connection string. Must end with
# `?sslmode=require`. Prisma 7 reads this from prisma.config.ts, and the
# Prisma client uses the Neon serverless driver.
DATABASE_URL=postgresql://user:password@ep-your-host.neon.tech/neondb?sslmode=require

# Optional: direct (unpooled) URL for long migrations from your laptop.
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-your-host.neon.tech/neondb?sslmode=require

# Ultravox — https://www.ultravox.ai
# Get an API key from Dashboard → API Keys. Free tier is 30 minutes of calls.
# SERVER SECRET — never expose to the browser, never log it, never commit it.
ULTRAVOX_API_KEY=replace_me
